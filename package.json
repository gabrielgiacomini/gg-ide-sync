{
  "name": "gg-ide-sync",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "scripts": {
    "sync": "tsx scripts/sync.ts",
    "sync:skills": "tsx scripts/sync.ts --lane skills",
    "sync:agents": "tsx scripts/sync.ts --lane agents",
    "sync:workflows": "tsx scripts/sync.ts --lane workflows",
    "sync:rules": "tsx scripts/sync.ts --lane rules",
    "sync:submodules": "tsx scripts/sync.ts --lane submodules",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.ts",
    "typecheck": "tsc --noEmit --project tsconfig.json --pretty"
  },
  "peerDependencies": {
    "@types/node": ">=20",
    "js-yaml": ">=4",
    "sharp": ">=0.33",
    "tsx": ">=4",
    "typescript": ">=5"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@jest/globals": ">=29",
    "@types/node": ">=20",
    "jest": ">=29",
    "js-yaml": ">=4",
    "ts-jest": ">=29",
    "tsx": ">=4",
    "typescript": ">=5"
  }
}
